##	General
# Whitespaces on beginning are allowed
# Whitespaces at the end are allowed
# Whitespaces between fields are allowed
# Whitespaces in fields are forbidden
# Missing Values are forbidden
# More values than required are forbidden
# Incomplete Values like .2 will be 0.2

#---------------------------------------------------------------------------------------------------

# POINTS
# - Free range of values for X,Y,Z
# - Float and int values allowed
# - + and - values allowed

# VECTORS
# - [-1,1] range of values for X,Y,Z
# - Float and int values allowed
# - + and - values allowed
# - Vector must be normalized (magnitude = 1)

# FOV
# - Int values only
# - Range of values [0,180]

# COLORS
# - Int values only
# - Range of values [0,255]
# - Must have 3 Values separated by commas

# DIAMETERS AND HEIGHTS
# - Float and int values allowed
# - Free range of positive values


#---------------------------------------------------------------------------------------------------
##	Camera	VIEWPOINT(X,Y,Z)	ORIENTVECTOR(Normalized)	FOV

#valid
C	-100.0,300,02.0					0,0,1				70
#valid => 0.2.1.2 = 0.212
C	-100.0,300,0.2.1.2					0,0,1				70
#valid => 10-1000.0 = 10
C 10-1000.0,300,02.0					0,0,1				70

#invalid
C	-100.0,300,02.0					0,0,				70

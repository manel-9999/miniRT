C	-100.0,30002.0					0,0,1				70
#invalid
C	-100.0,300,0,2.0					0,0,1				70
#invalid
C	-100.0,3a00,02.0					0,0,1				70
#invalid
C	-100.0,300,02.0					0,0,1				-70
#invalid
C	-100.0,300,02.0					0,0,1
#invalid
C	-100.0,300,02.0					0,0,1				70 6


